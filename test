def get_fair(base_fair, requests, drivers)
    result = []
    for index in 0..requests.size-1 do
        if(drivers[index] = 0)
             result[index] = 0
        elsif(requests[index]>drivers[index])
            (requests[index]/drivers[index]).to_f * base_fair * requests[index]
        else
            result[index] = base_fair * requests[index]
        end
    end
    result
end

















