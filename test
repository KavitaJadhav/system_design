class Heap
    @drivers = []
    @size = 0


    def push(value)
        @drivers.push(value)
        heapfy_up
        @size+=1
    end

    def pop
        element = @drivers[0]
        @drivers[0], @drivers[@size-1] = @drivers[@size-1], nil
        @size-=1
        heapfy_down
        element
    end

    private
    def heapfy_down
    parent_index = 0
        loop do
            left_child = (parent_index * 2) + 1
            right_child = (parent_index * 2) + 2

        break if(left_child>=@size && right_child >= @size)
        if(left_child<@size && @drivers[left_child].distance < @drivers[parent].distance)
            @drivers[left_child] , @drivers[parent] =   @drivers[parent], @drivers[left_child]
        elsif(right_child<@size && @drivers[right_child].distance < @drivers[parent].distance)
                    @drivers[right_child] , @drivers[parent] =   @drivers[parent], @drivers[right_child]

        end
    end

    def heapfy_up
    loop do
        nodeIndex = @drivers.last - 1
        parent_index = (nodeIndex - 1)/2

        break if( parent_index<0)

        if @drivers[parent_index].distance < @drivers[nodeIndex].distance
            @drivers[parent_index], @drivers[nodeIndex] = @drivers[nodeIndex] ,  @drivers[parent_index]
    end
    end
end

